---
const { email, phone, formspreeId } = Astro.props;
---
<section id="contact" class="grid grid-cols-1 lg:grid-cols-2">
  <!-- Left info -->
  <div class="bg-sage-faint flex flex-col justify-center px-12 lg:px-20 py-24 border-b lg:border-b-0 lg:border-r border-sage/15">
    <div class="section-label">Contact</div>
    <h2 class="font-serif text-4xl lg:text-5xl font-light text-deep mb-5">Let's preserve<br/>your memories.</h2>
    <p class="text-[0.93rem] text-mid font-light leading-relaxed max-w-sm mb-10">Have flowers to preserve? A wedding approaching? We'd love to hear from you. Every commission begins with a conversation.</p>
    {[
      { label:'Email',             value: email },
      { label:'Phone & WhatsApp',  value: phone },
      { label:'Studio Location',   value:'Oviedo, Florida, USA' },
      { label:'Response Time',     value:'Within 24 hours' },
    ].map(d => (
      <div class="flex items-start gap-5 mb-6">
        <div class="w-0.5 min-h-[32px] bg-sage opacity-55 flex-shrink-0 mt-0.5"></div>
        <div>
          <strong class="block text-[0.74rem] tracking-widest uppercase text-soft mb-0.5">{d.label}</strong>
          <span class="text-[0.95rem] text-deep font-light">{d.value}</span>
        </div>
      </div>
    ))}
    <div class="mt-6 pt-6 border-t border-sage/15 text-[0.76rem] tracking-widest uppercase text-soft">Mon – Fri · 10am – 5pm EST</div>
  </div>

  <!-- Right form -->
  <div class="bg-cream-mid flex flex-col justify-center px-12 lg:px-20 py-24">
    <div class="section-label">Send a Message</div>
    <form id="contactForm" action={`https://formspree.io/f/${formspreeId}`} method="POST">
      <input type="hidden" name="_subject" id="emailSubject" value="New Inquiry – Nast Bloom" />
      <input type="text" name="_gotcha" class="hidden" />

      <div class="grid grid-cols-2 gap-4 mb-5">
        <div>
          <label class="block text-[0.76rem] tracking-widest uppercase text-mid mb-2">First Name</label>
          <input type="text" name="first_name" placeholder="Jane" required class="w-full bg-transparent border-b border-black/15 pb-3 text-[0.95rem] text-deep font-light outline-none focus:border-sage transition-colors placeholder:text-faint" />
        </div>
        <div>
          <label class="block text-[0.76rem] tracking-widest uppercase text-mid mb-2">Last Name</label>
          <input type="text" name="last_name" placeholder="Smith" class="w-full bg-transparent border-b border-black/15 pb-3 text-[0.95rem] text-deep font-light outline-none focus:border-sage transition-colors placeholder:text-faint" />
        </div>
      </div>
      <div class="mb-5">
        <label class="block text-[0.76rem] tracking-widest uppercase text-mid mb-2">Email</label>
        <input type="email" name="email" placeholder="jane@example.com" required class="w-full bg-transparent border-b border-black/15 pb-3 text-[0.95rem] text-deep font-light outline-none focus:border-sage transition-colors placeholder:text-faint" />
      </div>
      <div class="mb-5">
        <label class="block text-[0.76rem] tracking-widest uppercase text-mid mb-2">Inquiry Type</label>
        <select name="inquiry_type" class="w-full bg-transparent border-b border-black/15 pb-3 text-[0.95rem] text-deep font-light outline-none focus:border-sage transition-colors appearance-none">
          <option>Wedding Bouquet Preservation</option>
          <option>Custom Resin Block</option>
          <option>Pressed Flower Frame</option>
          <option>Letters</option>
          <option>Specialty Item</option>
          <option>Add-Ons & Upgrades</option>
          <option>Shipping Question</option>
          <option>General Question</option>
        </select>
      </div>
      <div class="mb-5">
        <label class="block text-[0.76rem] tracking-widest uppercase text-mid mb-2">Message</label>
        <textarea name="message" placeholder="Tell us about your flowers…" required rows="3" class="w-full bg-transparent border-b border-black/15 pb-3 text-[0.95rem] text-deep font-light outline-none focus:border-sage transition-colors resize-none placeholder:text-faint"></textarea>
      </div>
      <button type="submit" id="submitBtn" class="bg-sage text-white text-[0.82rem] tracking-widest uppercase px-10 py-4 hover:bg-sage/80 transition-colors mt-2">Send Message</button>
      <p id="formSuccess" class="hidden mt-4 text-[0.88rem] text-sage font-light">✦ Message sent! We'll be in touch within 24 hours.</p>
      <p id="formError" class="hidden mt-4 text-[0.88rem] text-red-500 font-light"></p>
    </form>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    if (!form) return;
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('submitBtn') as HTMLButtonElement;
      const successMsg = document.getElementById('formSuccess');
      const errorMsg = document.getElementById('formError');
      btn.textContent = 'Sending…'; btn.disabled = true;
      if (successMsg) successMsg.style.display = 'none';
      if (errorMsg) errorMsg.style.display = 'none';
      const data = new FormData(form);
      const firstName = (form.querySelector('[name="first_name"]') as HTMLInputElement)?.value || '';
      const lastName  = (form.querySelector('[name="last_name"]')  as HTMLInputElement)?.value || '';
      const inquiry   = (form.querySelector('[name="inquiry_type"]') as HTMLSelectElement)?.value || 'Inquiry';
      const email     = (form.querySelector('[name="email"]') as HTMLInputElement)?.value || '';
      data.set('_subject', `New Inquiry from ${firstName} ${lastName} – ${inquiry}`);
      data.set('_replyto', email);
      try {
        const res  = await fetch(form.action, { method:'POST', body:data, headers:{'Accept':'application/json'} });
        const json = await res.json();
        if (res.ok && json.ok) {
          btn.textContent = '✓ Message Sent!';
          btn.style.background = '#8fa882';
          if (successMsg) successMsg.style.display = 'block';
          form.reset();
          window.showToast?.('🌸 Message sent! We will be in touch within 24 hours.');
          setTimeout(() => { btn.textContent='Send Message'; btn.style.background=''; btn.disabled=false; if(successMsg)successMsg.style.display='none'; }, 6000);
        } else {
          const err = json.errors ? json.errors.map((e: any) => e.message).join(', ') : 'Submission failed';
          btn.textContent='Try Again'; btn.disabled=false;
          if(errorMsg){ errorMsg.textContent='Error: '+err; errorMsg.style.display='block'; }
        }
      } catch(err) {
        btn.textContent='Try Again'; btn.disabled=false;
        if(errorMsg){ errorMsg.textContent='Network error. Please email nina@nastbloom.com directly.'; errorMsg.style.display='block'; }
      }
    });
  });
</script>
