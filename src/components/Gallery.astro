---
const { items } = Astro.props;
const featured = items.find((i: any) => i.data.featured);
const rest = items.filter((i: any) => !i.data.featured);
---
<section id="gallery" class="bg-sage-faint py-28 px-12 lg:px-20">
  <div class="text-center mb-14">
    <div class="section-label justify-center">Our Work</div>
    <h2 class="font-serif text-4xl lg:text-5xl font-light text-deep">Forever flowers, beautifully preserved.</h2>
    <p class="text-[0.88rem] text-mid font-light mt-3">Hover any photo and click to upload your work. Your gallery updates instantly.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 auto-rows-[260px] gap-1">
    {[featured, ...rest].filter(Boolean).map((item: any, i: number) => (
      <div
        class:list={['gallery-item relative overflow-hidden cursor-pointer group bg-cream-mid border border-black/10', item?.data?.featured ? 'lg:row-span-2' : '']}
        id={`gitem-${item.slug}`}
      >
        <div class="g-slot w-full h-full flex flex-col items-center justify-center gap-2 transition-transform duration-500 group-hover:scale-[1.04] relative" id={`gslot-${item.slug}`}>
          {item.data.image ? (
            <img src={item.data.image} alt={item.data.title} class="w-full h-full object-cover absolute inset-0 g-preview" />
          ) : (
            <>
              <span class="text-4xl opacity-25">🌸</span>
              <span class="text-[0.72rem] tracking-widest uppercase text-faint">{item.data.title}</span>
            </>
          )}
        </div>
        <label
          for={`gfile-${item.slug}`}
          class="absolute bottom-2 right-2 z-10 bg-linen/92 border border-black/15 text-soft text-[0.62rem] tracking-widest uppercase px-3 py-1.5 cursor-pointer hover:bg-sage hover:text-white hover:border-sage transition-all opacity-0 group-hover:opacity-100"
        >
          + Upload Photo
        </label>
        <input type="file" accept="image/*" id={`gfile-${item.slug}`} data-slug={item.slug} class="hidden gallery-upload-input" />
        <div class="gallery-caption absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-deep/55 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
          <span class="font-serif italic text-white/95 text-[0.95rem]">{item.data.title}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll('.gallery-upload-input').forEach(input => {
    const inp = input as HTMLInputElement;
    const slug = inp.dataset.slug;
    if (!slug) return;

    // Restore saved photo
    const saved = localStorage.getItem(`nb_gimg_${slug}`);
    if (saved) applyGalleryImg(slug, saved);

    inp.addEventListener('change', function() {
      const f = this.files?.[0]; if (!f) return;
      const r = new FileReader();
      r.onload = e => {
        const src = e.target?.result as string;
        try { localStorage.setItem(`nb_gimg_${slug}`, src); } catch(err) {}
        applyGalleryImg(slug!, src);
        window.showToast?.('📷 Gallery saved!');
      };
      r.readAsDataURL(f);
    });
  });

  function applyGalleryImg(slug: string, src: string) {
    const slot = document.getElementById(`gslot-${slug}`);
    if (!slot) return;
    // Remove placeholder
    slot.querySelectorAll('span').forEach(s => s.remove());
    let img = slot.querySelector('.g-preview') as HTMLImageElement;
    if (!img) {
      img = document.createElement('img');
      img.className = 'w-full h-full object-cover absolute inset-0 g-preview';
      slot.prepend(img);
    }
    img.src = src;
  }
</script>
