---
import '../styles/global.css';

const settings = await import('../content/settings/general.json').then(m => m.default).catch(() => ({
  siteTitle: 'Nast Bloom',
  tagline: 'Preserve. Treasure. Remember.',
  email: 'nina@nastbloom.com',
  phone: '+1 (561) 827-1289',
  instagram: 'nast.bloom',
  facebook: 'nastbloom',
  tiktok: 'nastbloom',
}));

const { title = settings.siteTitle } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Nast Bloom – Handcrafted flower preservation. Wedding bouquets and special blooms preserved in museum-grade resin. Based in Oviedo, FL." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body class="bg-cream font-sans text-deep overflow-x-hidden">

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-cream/97 backdrop-blur-md border-b border-black/10 h-[72px] flex items-center justify-between px-10">
    <ul class="hidden md:flex gap-8 list-none">
      <li><a href="#home"    class="nav-link text-[0.8rem] tracking-widest uppercase text-mid hover:text-deep transition-colors">Home</a></li>
      <li><a href="#about"   class="nav-link text-[0.8rem] tracking-widest uppercase text-mid hover:text-deep transition-colors">About</a></li>
      <li><a href="#process" class="nav-link text-[0.8rem] tracking-widest uppercase text-mid hover:text-deep transition-colors">Process</a></li>
      <li><a href="#gallery" class="nav-link text-[0.8rem] tracking-widest uppercase text-mid hover:text-deep transition-colors">Gallery</a></li>
    </ul>

    <a href="#home" class="absolute left-1/2 -translate-x-1/2">
      <img src="/images/logo.png" alt="Nast Bloom" class="h-14 w-auto" onerror="this.style.display='none';this.nextElementSibling.style.display='block'"/>
      <span class="hidden font-serif text-2xl text-deep italic">Nast Bloom</span>
    </a>

    <div class="flex items-center gap-6">
      <ul class="hidden md:flex gap-8 list-none items-center">
        <li><a href="#faq"     class="text-[0.8rem] tracking-widest uppercase text-mid hover:text-deep transition-colors">FAQ</a></li>
        <li><a href="#contact" class="text-[0.8rem] tracking-widest uppercase text-mid hover:text-deep transition-colors">Contact</a></li>
      </ul>
      <button onclick="openCart()" class="flex items-center gap-2 text-[0.8rem] tracking-widest uppercase text-mid hover:text-gold transition-colors relative">
        <span class="relative inline-block">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M1 1h2.5l1.7 8.5h8l1.5-6H4.5"/>
            <circle cx="8" cy="15.5" r="1.2" fill="currentColor" stroke="none"/>
            <circle cx="13" cy="15.5" r="1.2" fill="currentColor" stroke="none"/>
          </svg>
          <span id="cartCount" class="absolute -top-1.5 -right-2 bg-gold text-white text-[0.55rem] min-w-[16px] h-4 rounded-full flex items-center justify-center px-0.5">0</span>
        </span>
        Cart
      </button>
      <a href="#contact" class="hidden md:block bg-gold text-linen text-[0.78rem] tracking-widest uppercase px-5 py-2 hover:bg-gold/80 transition-colors">Inquire</a>
    </div>
  </nav>

  <!-- PAGE CONTENT -->
  <slot />

  <!-- CTA BANNER -->
  <div class="bg-sage-faint border-t border-sage-line py-20 px-20 grid grid-cols-1 md:grid-cols-3 gap-12 items-center">
    <div>
      <h2 class="font-serif text-4xl font-light text-deep">Let's preserve<br>your memories.</h2>
      <p class="text-[0.95rem] text-mid font-light mt-2">Preserve. Treasure. Remember.</p>
    </div>
    <div class="hidden md:flex justify-center">
      <img src="/images/logo.png" alt="Nast Bloom" class="h-20 w-auto" onerror="this.style.display='none'"/>
    </div>
    <div class="flex md:justify-end">
      <a href="#contact" class="bg-sage text-white text-[0.82rem] tracking-widest uppercase px-8 py-4 hover:bg-sage/80 transition-colors">Inquire Now</a>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="bg-deep pt-16 pb-8 px-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-16 mb-12 pb-12 border-b border-white/10">
      <div>
        <img src="/images/logo.png" alt="Nast Bloom" class="h-14 mb-6 opacity-70 brightness-200" onerror="this.style.display='none'"/>
        <p class="text-[0.88rem] text-white/35 font-light leading-loose max-w-[220px]">Handcrafted floral preservation — turning your precious blooms into timeless art. Based in Oviedo, FL.</p>
        <div class="flex gap-3 mt-6">
          <a href={`https://www.instagram.com/${settings.instagram}`} target="_blank" rel="noopener" class="w-8 h-8 border border-white/10 flex items-center justify-center text-white/40 hover:border-sage-light hover:text-sage-light transition-all">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href={`https://www.facebook.com/${settings.facebook}`} target="_blank" rel="noopener" class="w-8 h-8 border border-white/10 flex items-center justify-center text-white/40 hover:border-sage-light hover:text-sage-light transition-all">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={`https://www.tiktok.com/@${settings.tiktok}`} target="_blank" rel="noopener" class="w-8 h-8 border border-white/10 flex items-center justify-center text-white/40 hover:border-sage-light hover:text-sage-light transition-all">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        </div>
      </div>
      <div>
        <h4 class="text-[0.73rem] tracking-[0.18em] uppercase text-white/30 mb-6">Shop</h4>
        <ul class="list-none space-y-3">
          {['Resin Blocks','Specialty Items','Pressed Frames','Letters','Add-Ons','Custom Orders'].map(item => (
            <li><a href="#products" class="text-[0.88rem] text-white/45 font-light hover:text-white/85 transition-colors">{item}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-[0.73rem] tracking-[0.18em] uppercase text-white/30 mb-6">Studio</h4>
        <ul class="list-none space-y-3">
          {[['Our Story','#about'],['The Process','#process'],['Shipping Guide','#shipping'],['Gallery','#gallery'],['FAQ','#faq'],['Contact','#contact']].map(([label,href]) => (
            <li><a href={href} class="text-[0.88rem] text-white/45 font-light hover:text-white/85 transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-[0.73rem] tracking-[0.18em] uppercase text-white/30 mb-6">Policies</h4>
        <ul class="list-none space-y-3">
          {['Terms of Service','Refunds & Returns','Order Cancellation','Shipping Policy','Privacy Policy'].map(item => (
            <li><a href="#policies" class="text-[0.88rem] text-white/45 font-light hover:text-white/85 transition-colors">{item}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="flex justify-between items-center">
      <p class="text-[0.8rem] text-white/20 font-light">© 2025 Nast Bloom. All rights reserved. · Oviedo, FL</p>
      <span class="font-serif italic text-[0.8rem] text-white/25">Preserve. Treasure. Remember.</span>
    </div>
  </footer>

  <!-- CART SIDEBAR -->
  <div id="cartOverlay" onclick="closeCart()" class="fixed inset-0 bg-deep/35 z-[200] opacity-0 pointer-events-none transition-opacity duration-300"></div>
  <div id="cartSidebar" class="fixed right-0 top-0 bottom-0 w-[400px] bg-linen z-[201] translate-x-full transition-transform duration-300 ease-in-out flex flex-col border-l border-black/10 max-w-full">
    <div class="p-8 border-b border-black/10 flex items-center justify-between">
      <h3 class="font-serif text-2xl font-light text-deep">Cart</h3>
      <button onclick="closeCart()" class="text-soft text-[0.75rem] tracking-widest uppercase hover:text-deep transition-colors">Close ✕</button>
    </div>
    <div id="cartBody" class="flex-1 overflow-y-auto px-8 py-6">
      <div id="cartEmpty" class="text-center py-16 text-faint">
        <div class="text-4xl mb-4 opacity-40">🌸</div>
        <p class="text-[0.88rem] font-light leading-relaxed">Your cart is empty.<br/>Discover our collection.</p>
      </div>
    </div>
    <div class="px-8 pb-10 pt-4 border-t border-black/10">
      <div class="flex justify-between items-baseline mb-2">
        <span class="text-[0.78rem] tracking-widest uppercase text-soft">Subtotal</span>
        <span id="cartTotal" class="font-serif text-3xl font-light text-deep">$0.00</span>
      </div>
      <p id="minNote" class="hidden text-[0.8rem] text-soft italic mb-4">Minimum order of $250 required.</p>
      <button onclick="checkout()" class="w-full bg-sage text-white py-4 text-[0.82rem] tracking-widest uppercase hover:bg-sage/80 transition-colors mt-4">Proceed to Checkout</button>
    </div>
  </div>

  <!-- TOAST -->
  <div id="toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 translate-y-16 bg-deep text-white/88 px-8 py-3 text-[0.86rem] font-light border-l-2 border-sage-light opacity-0 transition-all duration-300 whitespace-nowrap z-[300]"></div>

  <script>
    // Cart
    let cart = JSON.parse(localStorage.getItem('nb_cart') || '[]');

    function saveCart() { localStorage.setItem('nb_cart', JSON.stringify(cart)); }

    function addToCart(id, name, price, emoji) {
      const ex = cart.find(x => x.id === id);
      if (ex) ex.qty++;
      else cart.push({ id, name, price, emoji, qty: 1 });
      saveCart(); updateCartUI();
      showToast(emoji + ' ' + name + ' added');
      openCart();
    }
    window.addToCart = addToCart;

    function removeFromCart(id) { cart = cart.filter(x => x.id !== id); saveCart(); updateCartUI(); }
    window.removeFromCart = removeFromCart;

    function updateQty(id, d) {
      const item = cart.find(x => x.id === id);
      if (!item) return;
      item.qty += d;
      if (item.qty <= 0) removeFromCart(id); else { saveCart(); updateCartUI(); }
    }
    window.updateQty = updateQty;

    function updateCartUI() {
      const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
      const count = cart.reduce((s, i) => s + i.qty, 0);
      document.getElementById('cartCount').textContent = count;
      document.getElementById('cartTotal').textContent = '$' + total.toFixed(2);
      const body = document.getElementById('cartBody');
      body.querySelectorAll('.cart-item').forEach(el => el.remove());
      document.getElementById('cartEmpty').style.display = cart.length ? 'none' : 'block';
      const minNote = document.getElementById('minNote');
      if (minNote) minNote.style.display = (cart.length && total < 250) ? 'block' : 'none';
      cart.forEach(item => {
        const el = document.createElement('div');
        el.className = 'cart-item flex gap-4 py-5 border-b border-black/10 items-start';
        el.innerHTML = `
          <div class="w-14 h-14 bg-cream-mid flex-shrink-0 flex items-center justify-center text-2xl border border-black/10">${item.emoji}</div>
          <div class="flex-1">
            <h4 class="font-serif text-base font-normal text-deep mb-0.5">${item.name}</h4>
            <span class="text-[0.82rem] text-soft font-light">$${item.price} each</span>
            <div class="flex items-center gap-2 mt-2">
              <button onclick="updateQty('${item.id}',-1)" class="w-6 h-6 border border-black/15 flex items-center justify-center text-mid hover:border-deep hover:text-deep transition-all text-sm">−</button>
              <span class="text-[0.85rem] min-w-[20px] text-center text-deep">${item.qty}</span>
              <button onclick="updateQty('${item.id}',1)" class="w-6 h-6 border border-black/15 flex items-center justify-center text-mid hover:border-deep hover:text-deep transition-all text-sm">+</button>
            </div>
          </div>
          <div class="flex flex-col items-end gap-2">
            <span class="font-serif text-lg font-normal text-deep">$${(item.price * item.qty).toFixed(2)}</span>
            <button onclick="removeFromCart('${item.id}')" class="text-faint text-[0.65rem] tracking-widest uppercase hover:text-deep transition-colors">Remove</button>
          </div>`;
        body.appendChild(el);
      });
    }

    function openCart() {
      document.getElementById('cartOverlay').classList.remove('opacity-0','pointer-events-none');
      document.getElementById('cartSidebar').classList.remove('translate-x-full');
    }
    function closeCart() {
      document.getElementById('cartOverlay').classList.add('opacity-0','pointer-events-none');
      document.getElementById('cartSidebar').classList.add('translate-x-full');
    }
    function checkout() {
      const total = cart.reduce((s,i) => s + i.price * i.qty, 0);
      if (!cart.length) { showToast('Your cart is empty'); return; }
      if (total < 250) { showToast('Minimum order of $250 required'); return; }
      showToast("Checkout coming soon — we'll be in touch!");
      setTimeout(closeCart, 800);
    }
    window.openCart = openCart;
    window.closeCart = closeCart;
    window.checkout = checkout;

    let toastTimer;
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.remove('opacity-0','translate-y-16');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => t.classList.add('opacity-0','translate-y-16'), 3200);
    }
    window.showToast = showToast;

    updateCartUI();
</script>

  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });

      window.netlifyIdentity.init();
    }
  </script>
</body>
</html>
